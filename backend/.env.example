# ─────────────────────────────────────────────────────────────────────────────
# Backend environment variable template
# Copy to .env and fill in real values before running the project.
# For production, set these as environment variables in Render dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# Django core
# Use cms.settings.production in production
DJANGO_SETTINGS_MODULE=cms.settings.development
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE_ME_generate_with_python_secrets
DEBUG=True

# Allowed hosts (comma-separated, no spaces)
# Production example: cms-backend.onrender.com,api.yourchurch.org
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# Database
DB_NAME=cms_church_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS — comma-separated list of allowed frontend origins
# Production example: https://cms-church.vercel.app,https://yourchurch.org
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# CSRF trusted origins (required in production — must match your backend domain)
# Example: https://cms-backend.onrender.com,https://api.yourchurch.org
CSRF_TRUSTED_ORIGINS=https://cms-backend.onrender.com

# Email (currently paused)
EMAIL_FROM=noreply@yourchurch.org

# Optional startup superuser bootstrap (used by ensure_superuser command)
SUPERUSER_EMAIL=admin@yourchurch.org
# Optional: if empty, username is derived from SUPERUSER_EMAIL (before '@')
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=CHANGE_ME_use_a_strong_random_password

# Cloudinary (https://cloudinary.com — required in production for media uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP variables are intentionally not used right now.
