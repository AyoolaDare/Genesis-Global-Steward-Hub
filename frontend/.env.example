# ─────────────────────────────────────────────────────────────────────────────
# Frontend environment variable template
# Copy to .env (local dev) or set in Vercel dashboard (production).
# All VITE_ variables are inlined into the build at compile time.
# ─────────────────────────────────────────────────────────────────────────────

# Full URL to the backend API
# Development: http://localhost:8000/api/v1
# Production:  https://cms-backend.onrender.com/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# Dev-only: target host for the Vite /api proxy (not needed in production builds)
# Docker: http://backend:8000  |  Local (no Docker): http://localhost:8000
VITE_API_PROXY_TARGET=http://backend:8000
